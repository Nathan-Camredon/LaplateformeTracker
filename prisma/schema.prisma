datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Student {
  id        Int      @id @default(autoincrement())
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  age       Int
  average   Float
}

model User {
  login     String
  password  String
}

model Grade{
  id        Int @id @default(autoincrement())
  value     Int
  subet     String
  studentid int
}