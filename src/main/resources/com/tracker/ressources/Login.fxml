<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.tracker.controller.LoginController"
      styleClass="root">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="60.0"/>
    </padding>

    <!-- Company logo at the top -->
    <ImageView fitWidth="500.0" preserveRatio="true">
        <Image url="@../images/laplateforme.png"/>
    </ImageView>

    <!-- Main form container with Glassmorphism styling -->
    <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="20.0"/>
        </padding>
        
        <VBox alignment="CENTER" spacing="25.0" styleClass="login-card" maxWidth="400.0">
            <!-- Username/ID Input Section -->
            <VBox spacing="8.0" fillWidth="true">
                <Label text="User ID" styleClass="label-bold"/>
                <TextField fx:id="userIdField" promptText="Enter your ID" styleClass="text-field-custom"/>
            </VBox>

            <!-- Password Input Section -->
            <VBox spacing="8.0" fillWidth="true">
                <Label text="Password" styleClass="label-bold"/>
                <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="text-field-custom"/>
            </VBox>

            <!-- Submit Button -->
            <Button text="SIGN IN" onAction="#handleLogin" prefWidth="400.0" 
                    styleClass="login-button"/>
        </VBox>
    </VBox>
</VBox>
