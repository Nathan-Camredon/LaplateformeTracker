<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/fxml" 
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="com.tracker.controller.StudentController"
    spacing="10"
    styleClass="dashboard-container">
    




    <!-- Table Header Row -->
    <HBox spacing="10" alignment="CENTER_LEFT" prefHeight="40.0">
        <padding>
            <Insets left="40" right="40" top="10" bottom="10"/>
        </padding>
        <Label fx:id="idHeader" text="ID" prefWidth="60" styleClass="column-header" onMouseClicked="#handleSortId" style="-fx-cursor: hand;"/>
        <Label fx:id="prenomHeader" text="Prenom" prefWidth="180" styleClass="column-header" onMouseClicked="#handleSortPrenom" style="-fx-cursor: hand;"/>
        <Label fx:id="nomHeader" text="Nom" prefWidth="180" styleClass="column-header" onMouseClicked="#handleSortNom" style="-fx-cursor: hand;"/>
        <Label fx:id="ageHeader" text="Age" prefWidth="60" styleClass="column-header" onMouseClicked="#handleSortAge" style="-fx-cursor: hand;"/>
        <Label fx:id="moyenneHeader" text="Moyenne" prefWidth="80" styleClass="column-header" onMouseClicked="#handleSortMoyenne" style="-fx-cursor: hand;"/>
        <Region prefWidth="100" />
    </HBox>

    <!-- Content Area with Vertical Separators -->
    <StackPane VBox.vgrow="ALWAYS">
        
        <HBox mouseTransparent="true" spacing="10">
            <padding>
                <Insets left="40" right="40"/>
            </padding>
            <Region prefWidth="60" style="-fx-border-color: rgba(255,255,255,0.1); -fx-border-width: 0 1 0 0;"/>
            <Region prefWidth="180" style="-fx-border-color: rgba(255,255,255,0.1); -fx-border-width: 0 1 0 0;"/>
            <Region prefWidth="180" style="-fx-border-color: rgba(255,255,255,0.1); -fx-border-width: 0 1 0 0;"/>
            <Region prefWidth="60" style="-fx-border-color: rgba(255,255,255,0.1); -fx-border-width: 0 1 0 0;"/>
            <Region prefWidth="80" style="-fx-border-color: rgba(255,255,255,0.1); -fx-border-width: 0 1 0 0;"/>
            <Region prefWidth="100"/>
        </HBox>

        <!-- Scrollable List of Students -->
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0;">
            <VBox fx:id="studentList" spacing="5">


            </VBox>
        </ScrollPane>
    </StackPane>
</VBox>
